{
  "expo": {
    "name": "SunFlower",
    "slug": "SunFlower",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logoApp.png",
    "scheme": "sunflower",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.SunFlower",
      "icon": "./assets/images/logoApp.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logoApp.png",
        "backgroundColor": "#FCD34D"
      },
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.SunflowerData"
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/images/logoApp.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logoMain.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FCD34D"
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-secure-store",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "988edb8a-fd0e-46d8-a5ae-8a5eb3ad7b42"
      }
    }
  }
}
